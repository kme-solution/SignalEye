{
  "Service": {
    "Name": "device-gateway-service"
  },
  "MessageTransport": {
    "Type": "RabbitMq"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "",
    "Password": "",
    "RawMqttExchange": "signaleye.raw-mqtt",
    "RawMqttQueue": "signaleye.raw-mqtt.device-gateway",
    "RoutingKey": "raw-mqtt"
  },
  "TelemetryLogging": {
    "Directory": "logs",
    "MaxDirectorySizeBytes": 1073741824,
    "RetentionDays": 7
  },
  "Gateway": {
    "Modbus": {
      "MappingPath": "config/modbus/edge-EN.csv"
    }
  }
}
