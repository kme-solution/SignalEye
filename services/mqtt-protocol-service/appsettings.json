{
  "Service": {
    "Name": "mqtt-protocol-service"
  },
  "Mqtt": {
    "Host": "localhost",
    "Port": 1883,
    "ClientId": "signaleye-mqtt-protocol-service",
    "TelemetryTopic": "signaleye/+/+/+/telemetry",
    "Username": "",
    "Password": "",
    "TlsEnabled": false,
    "QoS": 1,
    "ReconnectBackoffSeconds": 5
  },
  "MessageTransport": {
    "Type": "RabbitMq"
  },
  "RabbitMq": {
    "Host": "localhost",
    "Port": 5672,
    "Username": "",
    "Password": "",
    "RawMqttExchange": "signaleye.raw-mqtt",
    "RawMqttQueue": "signaleye.raw-mqtt.device-gateway",
    "RoutingKey": "raw-mqtt"
  },
  "TelemetryLogging": {
    "Directory": "logs"
  }
}
