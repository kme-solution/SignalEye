# Copy this file to .env and replace the password before starting the stack.
RABBITMQ_USERNAME=signaleye
RABBITMQ_PASSWORD=replace-with-a-long-random-password

# Keep infrastructure bound to loopback unless a firewall and authentication are configured.
MQTT_BIND_ADDRESS=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=signaleye-device
MQTT_PASSWORD=replace-with-a-long-random-password
RABBITMQ_MANAGEMENT_BIND_ADDRESS=127.0.0.1
